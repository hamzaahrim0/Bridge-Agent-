# Configuration LLM Ollama local
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b
LLM_TIMEOUT=300
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=450
OLLAMA_NUM_CTX=4096
OLLAMA_KEEP_ALIVE=10m
LLM_ROUTING_ENABLED=false
BRIDGE_MAX_INFERRED_DISCIPLINES=2
BRIDGE_LLM_MERGE_ENABLED=true
BRIDGE_MEDIATION_ENABLED=true
BRIDGE_MAX_MEDIATION_TERMS=1
BRIDGE_MAX_MEDIATION_PAIRS=1

# Configuration RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RAG_TOP_K=3
RAG_CONTEXT_CHARS=500

# Configuration ChromaDB
CHROMA_DB_PATH=./chroma_db

# Configuration GDID
GDID_PATH=./gdid/gdid.json
